# E2E mode env — loaded by `vite --mode e2e` (Playwright's webServer).
# Overrides .env.local so the browser hits LOCAL Supabase, never production.
# These are the CLI's well-known local-dev values (public-safe, not secrets).
# The service-role key is NOT here — it is injected at runtime by the
# `test:e2e` npm script from `supabase status`.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
